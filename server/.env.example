# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/nexachain

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Referral / ROI business rules
# Comma separated percentages per level (level 1 = direct referral)
REFERRAL_LEVEL_PERCENTAGES=10,5,3,2,1
MAX_REFERRAL_LEVELS=5

# Frontend origin allowed for CORS
CLIENT_ORIGIN=http://localhost:5173
